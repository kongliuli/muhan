<UserControl
    x:Class="ModernBoxes.Presentation.Views.AsyncResultIcon"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="44"
    Height="44">
    <Grid>
        <Border
            Padding="4,2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="3">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IconImage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IconImage, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="11"
                Foreground="{DynamicResource PrimaryTextBrush}"
                Text="{Binding IconText, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Border>
        <Image
            Width="32"
            Height="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Source="{Binding IconImage, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Stretch="Uniform" />
    </Grid>
</UserControl>

<UserControl
    x:Class="ModernBoxes.Presentation.Views.UCSearch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="400"
    d:DesignWidth="240"
    DataContext="{Binding SearchViewModel, Source={StaticResource Locator}}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <StackPanel Orientation="Vertical">
            <Border
                x:Name="SearchBorder"
                Margin="10,8,10,6"
                Padding="10,6"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="12"
                        Opacity="0.15"
                        ShadowDepth="2"
                        Color="#085bfd" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Margin="4,0,6,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Foreground="Gray"
                        Text="🔍" />
                    <Grid Grid.Column="1">
                        <TextBlock
                            Margin="2,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="Gray"
                            IsHitTestVisible="False"
                            Text="搜索应用、文件、文件夹、便签...">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox
                            x:Name="SearchTextBox"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource AccentBrush}"
                            FontSize="13"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            PreviewKeyDown="SearchTextBox_PreviewKeyDown"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <TextBlock
                        x:Name="ClearButton"
                        Grid.Column="2"
                        Margin="4,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        FontSize="16"
                        Foreground="Gray"
                        Text="×"
                        ToolTip="清除搜索">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.InputBindings>
                            <MouseBinding
                                Command="{Binding ClearSearchCommand}"
                                Gesture="LeftClick" />
                        </TextBlock.InputBindings>
                    </TextBlock>
                </Grid>
            </Border>

            <ListBox
                x:Name="ResultsListBox"
                Margin="8,0"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding SearchResults}"
                MouseDoubleClick="ResultsListBox_MouseDoubleClick"
                PreviewKeyDown="ResultsListBox_PreviewKeyDown"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="8,6"
                            CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Width="44"
                                    Margin="0,0,8,0"
                                    Padding="4,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="Application">
                                                    <Setter Property="Background" Value="#1976D2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="File">
                                                    <Setter Property="Background" Value="#F57C00" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Directory">
                                                    <Setter Property="Background" Value="#388E3C" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Note">
                                                    <Setter Property="Background" Value="#FBC02D" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="Menu">
                                                    <Setter Property="Background" Value="#757575" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="White"
                                        Text="{Binding IconText}" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="Gray"
                                        Text="{Binding Detail}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock
                Margin="8,20,8,0"
                HorizontalAlignment="Center"
                FontSize="13"
                Foreground="Gray"
                Text="未找到相关结果"
                Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</UserControl>

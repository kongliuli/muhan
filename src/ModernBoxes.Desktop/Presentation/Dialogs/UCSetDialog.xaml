<UserControl
    x:Class="ModernBoxes.Presentation.Dialogs.UCSetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:ModernBoxes.Presentation.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Margin="10"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{DynamicResource RegionBrush}"
    DataContext="{Binding UCSetDialogViewModel, Source={StaticResource Locator}}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <local:ReverseBoolConvert x:Key="reverseBoolConvert" />
    </UserControl.Resources>
    <hc:TransitioningContentControl>
        <StackPanel Orientation="Vertical">
            <Expander Margin="10" Header="外观">
                <StackPanel Orientation="Vertical">
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="主题" />
                        <RadioButton
                            x:Name="RB_light"
                            Margin="20,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Click="RB_light_Click"
                            Content="明亮系"
                            IsChecked="True"
                            Style="{StaticResource RadioButtonIcon}" />
                        <RadioButton
                            Name="RB_Dark"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Click="RB_Dark_Click"
                            Content="暗黑系"
                            Style="{StaticResource RadioButtonIcon}" />
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="透明度" />
                        <Slider
                            Name="S_ModernBoxOpacity"
                            Width="400"
                            VerticalAlignment="Center"
                            hc:TipElement.Placement="Top"
                            hc:TipElement.StringFormat="#0%"
                            hc:TipElement.Visibility="Visible"
                            Maximum="1"
                            Minimum="0.15"
                            TickFrequency="0.1"
                            TickPlacement="Both"
                            Value="{Binding WindowOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <Expander Margin="10" Header="布局">
                <StackPanel Margin="10" Orientation="Vertical">
                    <hc:Divider
                        HorizontalContentAlignment="Left"
                        Content="主窗口"
                        FontSize="22"
                        LineStrokeThickness="2" />
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="木函悬停" />
                        <RadioButton
                            x:Name="RB_HoverOpen"
                            Margin="20,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Click="RB_HoverOpen_Click"
                            Content="开启"
                            IsChecked="false"
                            Style="{StaticResource RadioButtonIcon}" />
                        <RadioButton
                            x:Name="RB_HoverClose"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Click="RB_HoverClose_Click"
                            Content="关闭"
                            IsChecked="{Binding ElementName=RB_HoverOpen, Path=IsChecked, Converter={StaticResource reverseBoolConvert}}"
                            Style="{StaticResource RadioButtonIcon}" />
                    </StackPanel>
                    <StackPanel
                        Margin="10"
                        IsEnabled="{Binding ElementName=RB_HoverOpen, Path=IsChecked}"
                        Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="悬停位置" />
                        <RadioButton
                            x:Name="RB_HoverLeft"
                            Margin="20,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Content="左侧悬停"
                            IsChecked="True"
                            Style="{StaticResource RadioButtonIcon}" />
                        <RadioButton
                            x:Name="RB_HoverRight"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Content="右侧悬停"
                            IsChecked="{Binding ElementName=RB_HoverLeft, Path=IsChecked, Converter={StaticResource reverseBoolConvert}}"
                            Style="{StaticResource RadioButtonIcon}" />
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="布局样式" />
                    </StackPanel>
                    <hc:Divider
                        HorizontalContentAlignment="Left"
                        Content="卡片应用"
                        FontSize="22"
                        LineStrokeThickness="2" />
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource TextBlockTitle}"
                            Text="宽度" />
                        <hc:PreviewSlider
                            x:Name="S_ComponentWidth"
                            Width="400"
                            Value="{Binding ComponentWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <hc:PreviewSlider.PreviewContent>
                                <Label
                                    Content="{Binding Path=(hc:PreviewSlider.PreviewPosition), RelativeSource={RelativeSource Self}}"
                                    ContentStringFormat="#0.00"
                                    Style="{StaticResource LabelPrimary}" />
                            </hc:PreviewSlider.PreviewContent>
                        </hc:PreviewSlider>
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="组件应用布局" />
                        <RadioButton
                            x:Name="RB_ShowLeft"
                            Margin="20,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Click="layoutinleft_Click"
                            Content="左侧展示"
                            Style="{StaticResource RadioButtonIcon}" />
                        <RadioButton
                            x:Name="RB_ShowRight"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            Click="layoutinright_Click"
                            Content="右侧展示"
                            IsChecked="True"
                            Style="{StaticResource RadioButtonIcon}" />
                    </StackPanel>
                </StackPanel>
            </Expander>
            <Expander Margin="10" Header="通用">
                <StackPanel Orientation="Vertical">
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="开机自启" />
                        <StackPanel Margin="50,0,0,0" Orientation="Horizontal">
                            <RadioButton
                                Name="RB_AutoOpen"
                                Click="RadioButton_Click"
                                Content="是"
                                IsChecked="False" />
                            <RadioButton
                                Name="RB_NotAutoOpen"
                                Margin="10,0,0,0"
                                Click="RadioButton_Click_1"
                                Content="否"
                                IsChecked="{Binding ElementName=RB_AutoOpen, Path=IsChecked, Converter={StaticResource reverseBoolConvert}}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Expander>
            <Expander Margin="10" Header="快捷键">
                <StackPanel Orientation="Vertical">
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock
                            Width="120"
                            VerticalAlignment="Center"
                            Style="{StaticResource TextBlockTitle}"
                            Text="显示/隐藏窗口" />
                        <TextBox
                            x:Name="TbShowHideHotkey"
                            Width="200"
                            VerticalAlignment="Center"
                            IsReadOnly="True"
                            IsReadOnlyCaretVisible="False"
                            PreviewKeyDown="TbShowHideHotkey_PreviewKeyDown"
                            PreviewMouseDown="TbShowHideHotkey_PreviewMouseDown"
                            LostFocus="TbShowHideHotkey_LostFocus"
                            Text="{Binding ShowHideHotkey, UpdateSourceTrigger=Explicit}" />
                        <Button
                            x:Name="BtnClearShowHide"
                            Width="60"
                            Margin="8,0,0,0"
                            Click="BtnClearShowHide_Click"
                            Content="清除" />
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock
                            Width="120"
                            VerticalAlignment="Center"
                            Style="{StaticResource TextBlockTitle}"
                            Text="快速新建便签" />
                        <TextBox
                            x:Name="TbQuickNoteHotkey"
                            Width="200"
                            VerticalAlignment="Center"
                            IsReadOnly="True"
                            IsReadOnlyCaretVisible="False"
                            PreviewKeyDown="TbQuickNoteHotkey_PreviewKeyDown"
                            PreviewMouseDown="TbQuickNoteHotkey_PreviewMouseDown"
                            LostFocus="TbQuickNoteHotkey_LostFocus"
                            Text="{Binding QuickNoteHotkey, UpdateSourceTrigger=Explicit}" />
                        <Button
                            x:Name="BtnClearQuickNote"
                            Width="60"
                            Margin="8,0,0,0"
                            Click="BtnClearQuickNote_Click"
                            Content="清除" />
                    </StackPanel>
                    <TextBlock
                        Margin="10,0,10,10"
                        Foreground="Gray"
                        Text="建议使用 Ctrl+Shift / Ctrl+Alt / Win+Shift 加单个字母的组合"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Expander>
            <Expander Margin="10" Header="插件">
                <StackPanel Margin="10" DataContext="{Binding PluginManagerViewModel, Source={StaticResource Locator}}" Orientation="Vertical">
                    <TextBlock
                        Margin="0,0,0,8"
                        Foreground="Gray"
                        Text="{Binding StatusMessage}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="11"
                        Foreground="Gray"
                        Text="{Binding LocalFlowPaths}"
                        TextWrapping="Wrap" />
                    <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                        <Button
                            Width="160"
                            Command="{Binding ImportFlowCommand}"
                            Content="导入本机 Flow/Wox" />
                        <Button
                            Width="140"
                            Margin="12,0,0,0"
                            Command="{Binding RefreshStoreCommand}"
                            Content="加载 Flow 商店" />
                    </StackPanel>
                    <!--  双击安装不能用 InputBindings：ListBoxItem 会把 MouseLeftButtonDown 标记为已处理，手势收不到  -->
                    <ListBox
                        Height="160"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding StorePlugins}"
                        MouseDoubleClick="StorePluginList_MouseDoubleClick"
                        SelectedItem="{Binding SelectedStorePlugin, Mode=TwoWay}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="11"
                        Foreground="Gray"
                        Text="提示：Flow 商店 = 搜索插件（Alt+Space）；卡片小组件见 docs/active/plugin-development.md" />
                </StackPanel>
            </Expander>
            <Expander Margin="10" Header="数据恢复">
                <StackPanel Margin="10" Orientation="Vertical">
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <Button
                            Width="120"
                            Command="{Binding BackupDataCommand}"
                            Content="导出备份" />
                        <Button
                            Width="120"
                            Margin="20,0,0,0"
                            Command="{Binding RestoreDataCommand}"
                            Content="导入恢复" />
                    </StackPanel>
                </StackPanel>
            </Expander>
            <Expander Margin="10" Header="关于">
                <StackPanel Margin="10" Orientation="Vertical">
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="版本：" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding AboutVersion}" />
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource TextBlockTitle}" Text="作者：" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding AboutAuthor}" />
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontStyle="Italic"
                            Text="ModernBoxes · 木函桌面启动器" />
                    </StackPanel>
                </StackPanel>
            </Expander>
        </StackPanel>
    </hc:TransitioningContentControl>
</UserControl>

<UserControl
    x:Class="ModernBoxes.Presentation.Dialogs.AddNoteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:ModernBoxes.Presentation.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    DataContext="{Binding AddNoteDialogViewModel, Source={StaticResource Locator}}"
    mc:Ignorable="d">
    <hc:TransitioningContentControl Margin="10">
        <StackPanel Orientation="Vertical">
            <TextBox
                Margin="10,0,0,5"
                hc:InfoElement.Necessary="True"
                hc:InfoElement.Placeholder="标题"
                Style="{StaticResource TextBoxExtend}"
                Text="{Binding NoteTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox
                Height="120"
                Margin="10,10,0,5"
                AcceptsReturn="True"
                hc:InfoElement.Placeholder="内容"
                Style="{StaticResource TextBoxExtend}"
                Text="{Binding NoteContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />
            <StackPanel Margin="10" Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Text="颜色" />
                <ComboBox
                    x:Name="CbColor"
                    Width="120"
                    SelectedIndex="0"
                    SelectedValue="{Binding NoteColor, Mode=TwoWay}">
                    <ComboBoxItem Content="Moccasin" Tag="#FFE4B5" />
                    <ComboBoxItem Content="PowderBlue" Tag="#B0E0E6" />
                    <ComboBoxItem Content="PaleGreen" Tag="#98FB98" />
                    <ComboBoxItem Content="LightPink" Tag="#FFB6C1" />
                    <ComboBoxItem Content="White" Tag="#FFFFFF" />
                </ComboBox>
            </StackPanel>
            <Button
                Margin="10"
                HorizontalAlignment="Center"
                Command="{Binding SaveNote}"
                Content="确定"
                Style="{StaticResource ButtonPrimary}" />
        </StackPanel>
    </hc:TransitioningContentControl>
</UserControl>

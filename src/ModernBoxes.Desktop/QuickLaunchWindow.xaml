<Window
    x:Class="ModernBoxes.Desktop.QuickLaunchWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ModernBoxes.Presentation.Views"
    Title="木函"
    Width="640"
    Height="420"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Border
        CornerRadius="12"
        Background="{DynamicResource RegionBrush}">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="24"
                Opacity="0.35"
                ShadowDepth="0" />
        </Border.Effect>
        <views:UCSearch x:Name="SearchPanel" />
    </Border>
</Window>
